# ---------------------------------------------------------------------------
# Polymarket Paper Trading Bot - example configuration
# Copy to .env and adjust. ALL defaults are SAFE (paper trading only).
# ---------------------------------------------------------------------------

# --- Safety switches (do NOT enable live trading; this build cannot do it) ---
PAPER_TRADING=true
LIVE_TRADING=false

# --- Account ---
INITIAL_PAPER_BALANCE_USDC=1000

# --- Strategy toggles ---
ALLOW_NO=false

# --- Position / order sizing limits ---
MAX_TRADE_SIZE_USDC=5
MAX_TRADE_PCT=0.02            # max fraction of equity per single trade (0 = off)
MAX_POSITION_SIZE_USDC=25
MAX_DAILY_LOSS_USDC=20
MAX_WEEKLY_LOSS_USDC=50       # weekly circuit breaker: halts new buys until next week
MAX_OPEN_POSITIONS=5
MAX_MARKET_EXPOSURE_USDC=25
MAX_TOTAL_EXPOSURE_USDC=100

# --- Market filters ---
MAX_SPREAD=0.03
MIN_LIQUIDITY=500
MIN_HOURS_TO_CLOSE=24
EXIT_HOURS_BEFORE_CLOSE=6

# --- Entry / exit thresholds ---
ENTRY_PRICE_MAX=0.45
TAKE_PROFIT_PCT=0.15
STOP_LOSS_PCT=0.10

# --- Trend-based exit ---
TREND_WINDOW=5               # nº of recent snapshots used to gauge the trend
TREND_EXIT_PCT=0.25          # adverse mid move that forces an exit (0 = off)

# --- Market resolution (settle 0/1) ---
SETTLE_RESOLVED=true         # liquidate resolved markets to 0/1 (paper)

# --- Simulation realism ---
SLIPPAGE_BPS=10
FEE_BPS=0

# --- Runtime ---
POLL_INTERVAL_SECONDS=30
DASHBOARD_REFRESH_SECONDS=10
SCAN_LIMIT=200

# --- API base URLs (public, read-only) ---
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com

# --- Storage, logging & reports ---
DATABASE_URL=sqlite:///data/polymarket_paper_bot.db
LOG_LEVEL=INFO
REPORTS_DIR=data/reports
